---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://oecher-singsang.de/</loc>
    <lastmod>{{ collections.posts[0].date | isoDateTime }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://oecher-singsang.de/archive/</loc>
    <lastmod>{{ collections.posts[0].date | isoDateTime }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://oecher-singsang.de/impressum/</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
  {%- for post in collections.posts %}
  <url>
    <loc>https://oecher-singsang.de{{ post.url }}</loc>
    <lastmod>{{ post.date | isoDateTime }}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.8</priority>
  </url>
  {%- endfor %}
</urlset>
